{
  "name": "UserSeenPuzzle",
  "type": "object",
  "properties": {
    "puzzle_asin": {
      "type": "string",
      "description": "ASIN of the puzzle seen by user"
    }
  },
  "required": [
    "puzzle_asin"
  ],
  "rls": {
    "create": {},
    "read": {
      "created_by": "{{user.email}}"
    },
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}