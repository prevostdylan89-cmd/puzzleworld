{
  "name": "Friendship",
  "type": "object",
  "properties": {
    "requester_email": {
      "type": "string",
      "description": "Email de l'utilisateur qui envoie la demande"
    },
    "requester_name": {
      "type": "string",
      "description": "Nom de l'utilisateur qui envoie la demande"
    },
    "addressee_email": {
      "type": "string",
      "description": "Email de l'utilisateur qui re\u00e7oit la demande"
    },
    "addressee_name": {
      "type": "string",
      "description": "Nom de l'utilisateur qui re\u00e7oit la demande"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "accepted",
        "declined"
      ],
      "default": "pending",
      "description": "Statut de la demande d'amiti\u00e9"
    }
  },
  "required": [
    "requester_email",
    "addressee_email"
  ],
  "rls": {
    "create": {},
    "read": {
      "$or": [
        {
          "requester_email": "{{user.email}}"
        },
        {
          "addressee_email": "{{user.email}}"
        }
      ]
    },
    "update": {
      "$or": [
        {
          "requester_email": "{{user.email}}"
        },
        {
          "addressee_email": "{{user.email}}"
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "requester_email": "{{user.email}}"
        },
        {
          "addressee_email": "{{user.email}}"
        }
      ]
    }
  }
}